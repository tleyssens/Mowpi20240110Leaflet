void BuildNmea(void)
{
    strcpy(nmea, "");

    if (useDual) strcat(nmea, "$PAOGI,");
    else strcat(nmea, "$PANDA,");

    strcat(nmea, fixTime);
    strcat(nmea, ",");

    strcat(nmea, latitude);
    strcat(nmea, ",");

    strcat(nmea, latNS);
    strcat(nmea, ",");

    strcat(nmea, longitude);
    strcat(nmea, ",");
    strcat(nmea, lonEW);
    strcat(nmea, ",");
    // 6
    strcat(nmea, fixQuality);
    strcat(nmea, ",");
    strcat(nmea, numSats);
    strcat(nmea, ",");
    strcat(nmea, HDOP);
    strcat(nmea, ",");
    strcat(nmea, altitude);
    strcat(nmea, ",");
    //10
    strcat(nmea, ageDGPS);
    strcat(nmea, ",");
    //11
    strcat(nmea, speedKnots);
    strcat(nmea, ",");
    //12
    strcat(nmea, imuHeading);
    strcat(nmea, ",");
    //13
    strcat(nmea, imuRoll);
    strcat(nmea, ",");
    //14
    strcat(nmea, imuPitch);
    strcat(nmea, ",");
    //15
    strcat(nmea, imuYawRate);
    strcat(nmea, "*");

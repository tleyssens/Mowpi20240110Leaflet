function startParsing(socket, stream, s, socketList) {
  //stream.on('data', line => console.log(`> ${line}`))
  stream.on('data', function (data) { //ontvangt data van simulatie regel per regel
    //console.log('streamData', data)
    //socket.emit('nmea', data )// data.quality + " " + data.satellites + " " + data.hdop);//komt op ui/map
    try {
        gps.update(data); //stuur een regel door naar gps
        //console.log(data)
        //socket.emit('nmea', gps)//komt op ui/map
        s.gps = gps
        //socketList.emit('nmea', gps)
        
    } catch (e) {
        //if (s.debugGPS) {
            console.log(`gps not updated => error ${e.name}: ${e.message}`);
        //}
    }
  })
  gps.on('data', function (data) {
    //console.log('gps.data = ' + JSON.stringify(data, null, 4));
    if (s.debugGPS) {
      console.log('gpsData '+ JSON.stringify(data, null, 4));
    }
    if (gps.state.speed > 0 && gps.state.speed < 5) {
      //socket.emit('gpsState', gps.state);//data voor wijzerplaat en grafiek in mapsxx.html
      s.gps = gps
    }
  });
  gps.on('GGA', function (data) { //data bevat de huidige positie
    //var t0 = performance.now();
    //socketList.emit('quality', data.quality + " " + data.satellites + " " + data.hdop)//20201024
    /* if (s.debugGPS) {
      //io.emit('log', 'GGAdata= ' + JSON.stringify(data, null, 4));
    }*/
    s.data = data //20201124

    if (data.valid === false || data.lat === null || data.lon === null || gps.state.speed > 5 || data.lat < -90 || data.lat > 90 || data.lon < -180 || data.lon > 180) {
      //mower.stop()
      //io.emit('log', 'invalid data');
      return //check valid values
    }
  
    if (data.quality == 'rtk' || data.quality == 'rtk-float') { // || data.quality == 'dgps-fix' ) { // || data.quality == 'fix') {
      //io.emit('log','valid data');
      filter.update({
        A: A,
        B: B,
        C: C,
        H: H,
        R: R,
        Q: Q,
        u: u,
        y: $V([data.lat, data.lon])
      });
  
      data.position = {
        cov: filter.P.elements,
        pos: filter.x.elements
      };
      s.data = data
      gps.position = data.position

      if(s.contour.isRecordOn) {
        recordPath.update(gps.state)
      }
      
      //cc:Contour Opnemen#2; update pathplanning
      if(s.autoMow2) {
        pathPlan.update(gps)
        if (s.uTurn) {
          if (s.targetHeading == s.ABLine.heading) {
            if (s.NMEA.choice === "Simulatie") {
            	nmeaStream.nmea.steerangle = -80 //simulatie alleen?
            } //trager de bocht nemen anders maakt hij cirkels omdat de hoek te veel in 1 keer veranderd
            s.LM = s.autoMowBochtSpeedBinnensteWiel - 40// bocht onderkant LM 130 | RM 210 => draait te traag => binnenwiel vertragen 20201122
            s.RM = s.autoMowBochtSpeedBuitensteWiel + 20
          } else {
            if (s.NMEA.choice === "Simulatie") {
            	nmeaStream.nmea.steerangle = 80
            }
            s.LM = s.autoMowBochtSpeedBuitensteWiel // bocht bovenkant LM 210| RM 130 = OK
            s.RM = s.autoMowBochtSpeedBinnensteWiel
          }
        } else {
          sp1()
        }
      }
      if(s.mission.active) {
        //console.log('MissionActive')
        mission.update(gps, socketList)
        if (s.mission.data.MissionPlan.State > 105) {// was 5
          sp2()
        }
      } 
      socketList.emit('position', data) //20201024
      s.pos.prev.lat = data.position.pos[0];
      s.pos.prev.lon = data.position.pos[1];
      noRTKteller = 0
    } else {
      if (noRTKteller>5) {
        if(s.mission.active) {
        	s.LM = 0
        	s.RM = 0
        };
      } else {
        noRTKteller++
        //console.log('geen rtk = stoppen over %s seconden', 1 - noRTKteller/5)
      }
      //mower.stop()
    }
    if (s.driveEnable) { // Motoren aansturen
		  //driveTest("via gps")      
      mower.drive(s.LM,s.RM)
    } else {
      //mower.stop() //simulatie valt uit anders?
    }
    socketList.emit('s', s) 
  })
};

function runShellScript(filename) {
  var child = execFile(filename, [], (error, stdout, stderr) => {
    console.log(`${filename} uitvoeren`)
          if (error) {
              //throw error;
              console.log(`runShellScripterror ${error}`) // opgelet accent = backtick
              return
          }
          console.log(`${filename} uitgevoerd`)
      });
}
function map_range(value, low1, high1, low2, high2) {
  return low2 + (high2 - low2) * (value - low1) / (high1 - low1);
};
function sp1() {
  if(s.uTurn) {
   ctr.update(0)
   s.correction = 0 
  } else {
   s.correction = Math.round(ctr.update(-s.angleError)*10)/10;
   s.correction = clamp(s.correction, -90, 90);//-255,255//20200924
   //s.correction = map_range(s.correction, 255,-255,-s.autoMowSpeed, s.autoMowSpeed)
   console.log('cor = %s',s.correction)
    //   s.LM = s.correction > 0 ? s.autoMowSpeed : s.autoMowSpeed + s.correction;202010
    //   s.RM = s.correction > 0 ? s.autoMowSpeed - s.correction: s.autoMowSpeed;
    s.LM = s.correction > 0 ? s.autoMowSpeed : s.autoMowSpeed + ((s.autoMowSpeed/90) * s.correction); //20201115
    s.RM = s.correction > 0 ? s.autoMowSpeed - ((s.autoMowSpeed/90) * s.correction) : s.autoMowSpeed;
    s.PIDout = s.correction
  }
  
  //console.log(Object.getOwnPropertyNames(nmeaStream))
  if (s.NMEA.choice === "Simulatie") {
    //let sta = map_range(s.correction, 250,-250,-90,90)//45 was 90
    console.log('in sp1 angleError = %s ;targetHeading = %s; steerangle = %s',s.angleError,s.targetHeading,s.correction)
    //nmeaStream.nmea.steerangle = sta
    nmeaStream.nmea.steerangle = s.correction
    if (mower.state === 'stopped') {
      console.log('mower stopped')
      nmeaStream.nmea.stepDistance = 0
    }else {
      nmeaStream.nmea.stepDistance = 0.1
    }
  }
  if (s.NMEA.choice === "GPS") {
    console.log('LM:%s, RM:%s', s.LM, s.RM);      
  }
}

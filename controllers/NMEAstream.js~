function os_func() {
    this.execCommand = function (cmd, callback) {
        exec(cmd, (err, stdout, stderr) => {
            if (err) {
                console.log('error str2str' + err);
                //io.emit('log', err);
                return;
            }
            callback(stdout);
        });
    };
};


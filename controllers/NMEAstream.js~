async function run_shell_command(command) {
    let result;
    console.log('in run shell command : ' + command)
    try {
        result = await execProm(command);
    } catch(ex) {
        result = ex;
    }
    if ( Error[Symbol.hasInstance](result) )
        return ;

    return result;
}
//cc:touchbesturing#5; Motorsnelheden bepalen 
function steeringMath(X, Y) { //sturen met touchscreen
  //console.log('in steeringMath X:%s, Y:%s', X, Y);
  var V = (250 - Math.abs(X)) * (Y / 250) + Y;
  var W = (250 - Math.abs(Y)) * (X / 250) + X;
  var LM = (V + W) / 2; // - 17;
  var RM = (V - W) / 2; // + 4;
  let Mot = {
    'PIDout': 0,
    'LM': LM,
    'RM': RM
  };
  console.log('in scocketFunc steeringMath X:%s, Y:%s, LM:%s, RM:%s', X, Y, LM, RM);
  //io.emit('Mot', Mot);
  if (s.driveEnable) {
    //max snelheid instellen
    s.LM = map_range(LM, 250, -250, 255, -255)
    s.RM = map_range(RM, 250, -250, 255, -255)
    mower.drive(s.LM,s.RM)
  } else {
    mower.stop()   
  };
}

function map_range(value, low1, high1, low2, high2) {
  return low2 + (high2 - low2) * (value - low1) / (high1 - low1);
}
        console.log('in ToonTraject' + JSON.stringify(trajectPath, null, 4)); //traject[0].lat
        for (i = 0; i < trajectPath.length; i++) {
            placeMarker(trajectPath[i], map, '[' + i.toString() + ']');
        }
    }
    
    function disable() {
        map.setOptions({
            draggable: false,
            zoomControl: false,
            scrollwheel: false,
            disableDoubleClickZoom: false
        });
    }

    function enable() {
        map.setOptions({
            draggable: true,
            zoomControl: true,
            scrollwheel: true,
            disableDoubleClickZoom: true
        });
    }

